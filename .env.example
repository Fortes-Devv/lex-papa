# Copie este arquivo para .env (dev) e configure as mesmas chaves como
# Environment Variables no dashboard da Vercel (produção).

# Neon Postgres — Dashboard > Connection Details
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/lms?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/lms?sslmode=require"

# Auth.js — gerar com: npx auth secret
AUTH_SECRET=""

# Cloudinary — Dashboard > Settings > Access Keys
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Mercado Pago — Painel de Desenvolvedores > Credenciais
MERCADOPAGO_ACCESS_TOKEN=""
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=""
MERCADOPAGO_WEBHOOK_SECRET=""
